{
  "name": "lightfeed",
  "version": "v0.1.0b1",
  "description": "LightFeed – A plain RSS reader",
  "author": "mandrewcito",
  "homepage": "https://lightfeed.mandrewcito.dev",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
